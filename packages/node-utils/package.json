{
  "name": "@wgl-m/node-utils",
  "version": "2.0.0",
  "description": "Node-only utility functions",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=16"
  },
  "author": {
    "name": "Mr.Wang",
    "email": "17600980516@163.com",
    "url": "https://github.com/wangguanl"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wangguanl/wgl-monorepo",
    "directory": "packages/node-utils"
  },
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "await-to-js": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
