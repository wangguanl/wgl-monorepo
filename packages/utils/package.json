{
  "name": "@wgl-m/utils",
  "version": "2.0.0",
  "description": "Common utility functions for Node and Browser",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./es/*": {
      "import": {
        "types": "./dist/es/*.d.ts",
        "default": "./dist/es/*.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://wangguanl.github.io/page__package-utils/",
  "author": {
    "name": "Mr.Wang",
    "email": "17600980516@163.com",
    "url": "https://github.com/wangguanl"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wangguanl/wgl-monorepo",
    "directory": "packages/utils"
  },
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "docs": "vitepress dev docs",
    "docs:build": "vitepress build docs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "glob": "^10.4.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitepress": "1.6.3"
  }
}
